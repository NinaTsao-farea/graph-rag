AI_MODE=azure   # azure | gemini | local

# ─────────────────────────────────────────────────────────────
# Azure 陣營（公司筆電）
# ─────────────────────────────────────────────────────────────

# --- Azure OpenAI (Vision + GraphRAG LLM) ---
AZURE_OPENAI_API_KEY=在此輸入您的_Azure_Key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# 多部署擴充（可選，未設定則停止掃描）
# AZURE_OPENAI_DEPLOYMENT_2=gpt-4o-mini
# AZURE_OPENAI_API_KEY_2=（省略時沿用主要 Key）
# AZURE_OPENAI_ENDPOINT_2=（省略時沿用主要 Endpoint）

# --- Azure Document Intelligence ---
AZURE_COGNITIVE_SERVICES_ENDPOINT=https://your-di-resource.cognitiveservices.azure.com/
AZURE_COGNITIVE_SERVICES_KEY=在此輸入您的_DI_Key

# ─────────────────────────────────────────────────────────────
# Gemini 陣營（跨機器橋接陣營）
# ─────────────────────────────────────────────────────────────

# --- Google Gemini (Vision + GraphRAG LLM) ---
GEMINI_API_KEY=在此輸入您的_Gemini_Key
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────────────────────
# Local 陣營（個人電腦 + GPU）
# ─────────────────────────────────────────────────────────────

# --- Ollama (Vision 推論，本地執行) ---
# 啟用後 parse_tenders_local.py 將使用 Ollama 進行圖片描述
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_VISION_MODEL=qwen2.5-vl:7b          # 主要 Vision 模型

# 多 Vision 模型擴充（可選，依序掃描，空白即停止）
# OLLAMA_VISION_MODEL_2=llava:13b
# OLLAMA_VISION_MODEL_3=minicpm-v:8b

# 整頁渲染模式（補充向量圖，預設關閉；開啟後每頁截圖送 Vision，速度較慢）
OLLAMA_RENDER_FULL_PAGE=0
