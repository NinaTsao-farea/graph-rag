# 1. 2026 年新版要求在 models 區塊下進行註冊
models:
  # 負責文字生成、實體提取、摘要的工作馬
  completion_models:
    default_completion_model: # 這就是系統在找的 ID
      type: openai_chat
      model: gemini/gemini-3-flash
      api_key: ${GRAPHRAG_API_KEY}
      api_base: https://generativelanguage.googleapis.com/v1beta/openai/
      max_tokens: 4000
      temperature: 0.1

  # 負責將文字轉為數字向量的引擎
  embedding_models:
    default_embedding_model: # 系統預設會找這個 ID
      type: openai_embedding
      model: gemini/text-embedding-004
      api_key: ${GRAPHRAG_API_KEY}
      api_base: https://generativelanguage.googleapis.com/v1beta/openai/

# 2. 其他全域設定 (維持在頂層)
chunks:
  size: 1200
  overlap: 200

input:
  type: text
  base_dir: "input"
  file_pattern: ".*\\.md$$" # 記得我們之前的雙錢字號修正
  encoding: utf-8
